#!/bin/bash
#
#   ___ ___  _   _ _ __ | |_ __| | _____      ___ __
#  / __/ _ \| | | | '_ \| __/ _` |/ _ \ \ /\ / / '_ \
# | (_| (_) | |_| | | | | || (_| | (_) \ V  V /| | | |
#  \___\___/ \__,_|_| |_|\__\__,_|\___/ \_/\_/ |_| |_|
#
# countdown.sh - A simple Bash countdown timer that displays time in minutes and seconds
#
# Project: https://github.com/galaxy-cli/countdown

# Clean up terminal settings on exit
trap 'stty echo; echo -e "\ncountdown: Countdown cancelled"; exit 130' INT

# Check if pv is installed
if ! command -v pv >/dev/null 2>&1; then
  echo "This script requires 'pv'. Install it with: sudo apt install pv" >&2
  exit 1
fi

# Help hint for errors
try_help() {
  echo "Try 'countdown --help' for more information" >&2
  exit 1
}

usage() {
  cat <<EOF
DESCRIPTION
  A simplified, high-precision CLI timer using 'pv' for the progress bar.

USAGE
  countdown [OPTION]

OPTION
  -s SECONDS       Countdown in seconds
  -m MM:SS         Countdown in minutes and seconds
  -h H:MM:SS       Countdown in hours, minutes, and seconds
  --alert MESSAGE  Alert message to display via system notification
  --help           Show this help message

EXAMPLES
  countdown -m 05:00
  countdown -s 30 --alert "Check the oven!"
EOF
  exit 0
}

# --- TIME PARSERS ---
parse_minutes() {
  local input="$1"
  if [[ "$input" =~ ^([0-9]+):([0-9]{1,2})$ ]]; then
    echo "$(( 60 * 10#${BASH_REMATCH[1]} + 10#${BASH_REMATCH[2]} ))"
  elif [[ "$input" =~ ^[0-9]+$ ]]; then
    echo "$(( 60 * 10#$input ))"
  else
    echo "ERROR - Invalid -m format -- '$input'" >&2
    try_help
  fi
}

parse_hours() {
  local input="$1"
  if [[ "$input" =~ ^([0-9]+):([0-9]{1,2}):([0-9]{1,2})$ ]]; then
    echo "$(( 3600 * 10#${BASH_REMATCH[1]} + 60 * 10#${BASH_REMATCH[2]} + 10#${BASH_REMATCH[3]} ))"
  elif [[ "$input" =~ ^([0-9]+):([0-9]{1,2})$ ]]; then
    echo "$(( 3600 * 10#${BASH_REMATCH[1]} + 60 * 10#${BASH_REMATCH[2]} ))"
  elif [[ "$input" =~ ^[0-9]+$ ]]; then
    echo "$(( 3600 * 10#$input ))"
  else
    echo "ERROR - Invalid -h format -- '$input'" >&2
    try_help
  fi
}

# --- ARGUMENT PARSING ---
total_seconds=0
alert_message="Time's up!"
use_alert=false
flag_count=0

[[ $# -eq 0 ]] && try_help

while [[ $# -gt 0 ]]; do
  case "$1" in
    -s) 
      ((flag_count++)); shift
      [[ -z "$1" || ! "$1" =~ ^[0-9]+$ ]] && { echo "ERORR - Option requires a positive integer -- 's'" >&2; try_help; }
      total_seconds=$1 
      ;;
    -m) 
      ((flag_count++)); shift
      [[ -z "$1" ]] && { echo "ERROR - Option requires an argument -- 'm'" >&2; try_help; }
      total_seconds=$(parse_minutes "$1") 
      ;;
    -h) 
      ((flag_count++)); shift
      [[ -z "$1" ]] && { echo "ERROR - Option requires an argument -- 'h'" >&2; try_help; }
      total_seconds=$(parse_hours "$1") 
      ;;
    --alert) 
      shift
      [[ -z "$1" ]] && { echo "ERROR - Option requires an argument -- 'alert'" >&2; try_help; }
      use_alert=true; alert_message="$1" 
      ;;
    --help) 
      usage 
      ;;
    *) 
      echo "Unrecognized option '$1'" >&2
      try_help
      ;;
  esac
  shift
done

if [[ $flag_count -ne 1 || $total_seconds -le 0 ]]; then
  [[ $flag_count -gt 1 ]] && echo "ERROR - Please use only one time option (-s, -m, or -h)" >&2
  try_help
fi

# --- COUNTDOWN EXECUTION ---
printf "Countdown started: %d seconds\n" "$total_seconds"
yes | head -c "$total_seconds" | pv -p -t -e -L 1 -s "$total_seconds" > /dev/null

# --- COMPLETION ---
if $use_alert; then
  command -v notify-send >/dev/null 2>&1 && notify-send "countdown" "$alert_message"
  echo -e "\n$alert_message"
else
  echo -e "\nTime's up!"
fi